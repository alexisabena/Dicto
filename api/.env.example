OPENAI_API_KEY=sk-...
PORT=3000
DATA_DIR=/var/expedicta/data
NODE_ENV=development

# PIN that grants access to the recorder
ACCESS_PIN=123456
# Random secret for signing session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=change-this-to-a-long-random-string

# Google Calendar
GOOGLE_CREDENTIALS_FILE=/opt/expedicta/api/google-credentials.json
CALENDAR_ID=primary
TZ_CLINIC=America/Mexico_City
DOCTOR_NAME=Dr. García

# Clinic schedule (edit for surgery days by changing WORK_DAYS or WORK_START/END)
WORK_START_HOUR=9
WORK_END_HOUR=19
WORK_DAYS=1,2,3,4,5
SLOT_DURATION_MIN=60
SLOT_BUFFER_MIN=15
DAYS_AHEAD=7
