OPENAI_API_KEY=sk-...
PORT=3000
DATA_DIR=/var/expedicta/data
NODE_ENV=development

# PIN that grants access to the recorder
ACCESS_PIN=123456
# Random secret for signing session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=change-this-to-a-long-random-string

# Google Calendar
GOOGLE_CREDENTIALS_FILE=/opt/expedicta/api/google-credentials.json
CALENDAR_ID=primary
TZ_CLINIC=America/Mexico_City
DOCTOR_NAME=Dr. Mario León

# Clinic schedule
# WORK_DAYS: 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat 7=Sun
WORK_DAYS=1,2,3,4,5,6
WORK_START_HOUR=8
LUNCH_START_HOUR=12
LUNCH_END_HOUR=13
WORK_END_HOUR=19
SAT_END_HOUR=12       # Saturday ends at noon
SLOT_DURATION_MIN=60
SLOT_BUFFER_MIN=0
DAYS_AHEAD=30

# Anthropic — Claude Haiku conversation engine
ANTHROPIC_API_KEY=sk-ant-...

# Kapso WhatsApp API
KAPSO_API_KEY=your-kapso-api-key
KAPSO_PHONE_NUMBER_ID=597907523413541
KAPSO_WEBHOOK_SECRET=your-webhook-secret   # from Kapso dashboard → Webhooks → secret_key
# WhatsApp group where personal + professional phones coexist.
# Escalations (medical content, media) are posted here as a brief abstract.
# Leave blank until Mario creates the group and shares the chat ID.
ESCALATION_CHAT_ID=
